_addon.name     = 'overlord'
_addon.author   = 'AI Assistant'
_addon.version  = '8.1'
_addon.commands = {'overlord', 'ol'}

local imgui = require('imgui')
local lfs = require('lfs')
local config = require('config')

-- Default configuration structure
local default_settings = {
    addon_directory = "", -- Kept empty to trigger the first-time setup prompt
    auto_refresh   = true,
    window_width   = 350,  -- Made slightly wider for the setup prompt text
    window_height  = 500,
    show_window    = true,
    master_active  = false,
    delay_ms       = 500,
    font_scale     = 1.0,
    text_color     = {1.0, 1.0, 1.0, 1.0},
    bg_color       = {0.06, 0.06, 0.06, 0.94},
    bg_image_path  = "",
    saved_states   = {}
}

local settings = config.load(default_settings)

local ignore_list = {
    ["overlord"]   = true,
    ["wincontrol"] = true,
    ["libs"]       = true,
}

-- State Management
local addon_list = {}
local search_query = imgui.CreateVarString("")
local show_config = false
local texture_loaded = false
local bg_texture = nil

-- UI ImGui Specific Wrappers
local imgui_addon_dir = imgui.CreateVarString(settings.addon_directory == "" and windower.addon_path or settings.addon_directory)
local imgui_auto_refresh = imgui.CreateVarBool(settings.auto_refresh)
local imgui_window_width = imgui.CreateVarInt(settings.window_width)
local imgui_window_height = imgui.CreateVarInt(settings.window_height)
local imgui_master_toggle = imgui.CreateVarBool(settings.master_active)
local imgui_delay_ms = imgui.CreateVarInt(settings.delay_ms)
local imgui_font_scale = imgui.CreateVarFloat(settings.font_scale)
local imgui_text_color = imgui.CreateVarFloat4(settings.text_color, settings.text_color, settings.text_color, settings.text_color)
local imgui_bg_color = imgui.CreateVarFloat4(settings.bg_color, settings.bg_color, settings.bg_color, settings.bg_color)
local imgui_bg_image = imgui.CreateVarString(settings.bg_image_path)

-- Command Execution Queue
local command_queue = {}
local last_command_time = 0

local function queue_command(command)
    table.insert(command_queue, command)
end

local function refresh_addon_list()
    -- Use user-configured directory if valid, fallback to default hook
    local path = settings.addon_directory ~= "" and settings.addon_directory or windower.addon_path
    if not path then return end
    
    -- Ensure trailing slash
    if path:sub(-1) ~= '/' and path:sub(-1) ~= '\\' then
        path = path .. '/'
    end

    for folder in lfs.dir(path) do
        local lower_folder = folder:lower()
        if folder ~= "." and folder ~= ".." and not ignore_list[lower_folder] then
            local attr = lfs.attributes(path .. folder)
            if attr and attr.mode == "directory" then
                if windower.file_exists(path .. folder .. '/' .. folder .. '.lua') then
                    if settings.saved_states[folder] == nil then
                        settings.saved_states[folder] = false
                    end
                end
            end
        end
    end

    addon_list = {}
    for name, is_on in pairs(settings.saved_states) do
        table.insert(addon_list, {name = name, active = is_on})
    end

    table.sort(addon_list, function(a, b)
        if a.active ~= b.active then
            return a.active and not b.active
        end
        return a.name:lower() < b.name:lower()
    end)
end

local function update_background_texture()
    local path = imgui.GetVarString(imgui_bg_image)
    if path ~= "" and windower.file_exists(windower.addon_path .. path) then
        bg_texture = imgui.load_texture(windower.addon_path .. path)
        texture_loaded = (bg_texture ~= nil)
    else
        texture_loaded = false
        bg_texture = nil
    end
end

-- Only run scanning if a directory has already been initialized
if settings.addon_directory ~= "" then
    refresh_addon_list()
    update_background_texture()
end

windower.register_event('addon command', function(cmd, ...)
    settings.show_window = not settings.show_window
    config.save(settings)
end)

windower.register_event('time change', function(new_time)
    local current_time = os.clock()
    local delay_seconds = settings.delay_ms / 1000
    
    if #command_queue > 0 and (current_time - last_command_time) >= delay_seconds then
        local next_cmd = table.remove(command_queue, 1)
        windower.send_command(next_cmd)
        last_command_time = current_time
    end
end)

-- Render Loop
windower.register_event('prerender', function()
    if not settings.show_window then return end

    local is_auto = imgui.GetVarBool(imgui_auto_refresh)
    local w = is_auto and 0 or imgui.GetVarInt(imgui_window_width)
    local h = is_auto and 0 or imgui.GetVarInt(imgui_window_height)
    
    local flags = imgui.WindowFlags.NoSavedSettings + imgui.WindowFlags.NoTitleBar
    if w == 0 or h == 0 then
        flags = flags + imgui.WindowFlags.AlwaysAutoResize
    else
        imgui.set_next_window_size(w, h, imgui.SetCond.Always)
    end

    imgui.set_window_font_scale(imgui.GetVarFloat(imgui_font_scale))

    imgui.push_style_color(imgui.Col.Text, imgui_text_color)
    imgui.push_style_color(imgui.Col.WindowBg, imgui_bg_color)

    local window_open, window_pressed = imgui.begin_window("Overlord", settings.show_window, flags)
    if not window_open then
        settings.show_window = false
        config.save(settings)
    end

    if texture_loaded and bg_texture then
        local win_pos_x, win_pos_y = imgui.get_window_position()
        local win_w, win_h = imgui.get_window_size()
        imgui.window_draw_list_add_image(bg_texture, win_pos_x, win_pos_y, win_pos_x + win_w, win_pos_y + win_h)
    end

    -- ==================== DRAG BAR IMPLEMENTATION ====================
    imgui.push_style_color(imgui.Col.Button, {0.2, 0.2, 0.2, 0.6})
    imgui.push_style_color(imgui.Col.ButtonHovered, {0.3, 0.3, 0.3, 0.8})
    imgui.push_style_color(imgui.Col.ButtonActive, {0.4, 0.4, 0.4, 1.0})
    
    imgui.button("::: Overlord Menu (Drag Here) :::", -1, 20)
    
    imgui.pop_style_color(3)
    -- =================================================================

    -- ==================== FIRST TIME SETUP PROMPT ====================
    if settings.addon_directory == "" then
        imgui.text_wrapped("Welcome to Overlord! Please confirm or enter your absolute Windower addons directory path below:")
        imgui.spacing()
        
        imgui.input_text("##addondir", imgui_addon_dir, 512)
        imgui.text_disabled("Default path auto-detected above.")
        imgui.spacing()
        
        if imgui.button("Save & Initialize Directory", -1, 30) then
            local chosen_path = imgui.GetVarString(imgui_addon_dir)
            if chosen_path ~= "" then
                settings.addon_directory = chosen_path
                config.save(settings)
                refresh_addon_list()
                update_background_texture()
                windower.add_to_chat(207, "Overlord: Addon path initialized successfully!")
            end
        end
        
        imgui.end_window()
        imgui.pop_style_color(2)
        return -- Block the rest of the interface layout until path is confirmed
    end
    -- =================================================================

    -- Header Controls (Only renders after path is set)
    if imgui.button("Refresh Folders") then
        refresh_addon_list()
        windower.add_to_chat(207, "Overlord: Folders resynced.")
    end
    imgui.same_line()
    
    if imgui.button("⚙ Config") then
        show_config = not show_config
    end
    
    -- [Rest of the layout rendering goes here...]
