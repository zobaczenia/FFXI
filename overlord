windower.register_event('time change', function(new_time)
    local current_time = os.clock()
    local delay_seconds = settings.delay_ms / 1000
    
    if #command_queue > 0 and (current_time - last_command_time) >= delay_seconds then
        local next_cmd = table.remove(command_queue, 1)
        windower.send_command(next_cmd)
        last_command_time = current_time
    end
end)

