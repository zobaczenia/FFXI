-- Command Execution Queue
local command_queue = {}
local last_command_time = 0

local function queue_command(command)
    table.insert(command_queue, command)
end

local function refresh_addon_list()
    local path = windower.addon_path
    if not path then return end
    
    for folder in lfs.dir(path) do
        local lower_folder = folder:lower()
        if folder ~= "." and folder ~= ".." and not ignore_list[lower_folder] then
            local attr = lfs.attributes(path .. folder)
            if attr and attr.mode == "directory" then
                if windower.file_exists(path .. folder .. '/' .. folder .. '.lua') then
                    if settings.saved_states[folder] == nil then
                        settings.saved_states[folder] = false
                    end
                end
            end
        end
    end

    addon_list = {}
    for name, is_on in pairs(settings.saved_states) do
        table.insert(addon_list, {name = name, active = is_on})
    end

    table.sort(addon_list, function(a, b)
        if a.active ~= b.active then
            return a.active and not b.active
        end
        return a.name:lower() < b.name:lower()
    end)
end

local function update_background_texture()
    local path = imgui.GetVarString(imgui_bg_image)
    if path ~= "" and windower.file_exists(windower.addon_path .. path) then
        bg_texture = imgui.load_texture(windower.addon_path .. path)
        texture_loaded = (bg_texture ~= nil)
    else
        texture_loaded = false
        bg_texture = nil
    end
end

refresh_addon_list()
update_background_texture()

